# tools/devblog ローカル実行用の環境変数
# 実際の値は絶対にコミットしないこと(.env は .gitignore 済み)

# 記事下書き生成(構成案・本文・自己批評)に使用する LLM API キー
# キー名はプロバイダ非依存(devblog.config.json の llm.apiKeyEnvVar で参照先を切り替え可能)。
# 現在の既定プロバイダは GLM-5.2(Z.ai)。https://z.ai でキーを発行する
# 別プロバイダに切り替える場合は devblog.config.json の llm.provider/model/baseUrl/apiKeyEnvVar を変更するだけでよい
DEVBLOG_LLM_API_KEY=

# 公開用リポジトリ(owner/repo 形式)。例: kochan-um/devblog
DEVBLOG_PUBLISH_REPO=

# 公開用リポジトリへの PR 作成権限を持つ fine-grained PAT
# 権限: Contents (read/write), Pull requests (read/write)。対象リポジトリを DEVBLOG_PUBLISH_REPO のみに絞ること
DEVBLOG_PUBLISH_REPO_TOKEN=
